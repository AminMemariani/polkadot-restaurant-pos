# Copy to `.env` and fill in. Never commit the real `.env`.
PORT=8080

# Stripe — get from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook signing secret. For local dev use `stripe listen` and copy
# the whsec_... it prints. For prod, the Webhook endpoint dashboard issues one.
STRIPE_WEBHOOK_SECRET=whsec_...

# Supabase — Project Settings → API in the dashboard.
SUPABASE_URL=https://nynoqpbadxpnkhrpskgf.supabase.co

# Service-role key. NEVER expose to clients; bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# JWT secret used to verify tokens issued by Supabase Auth.
# Project Settings → API → "JWT Secret".
SUPABASE_JWT_SECRET=...

# Comma-separated allowed origins for CORS (e.g. https://app.example.com,
# capacitor://localhost). Empty = allow all (development only).
ALLOWED_ORIGINS=
