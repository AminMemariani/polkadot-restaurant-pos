# Copy to `.env` and fill in. Never commit the real `.env`.
PORT=8080

# Stripe — get from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook signing secret. For local dev use `stripe listen` and copy
# the whsec_... it prints. For prod, the Webhook endpoint dashboard issues one.
STRIPE_WEBHOOK_SECRET=whsec_...

# Comma-separated allowed origins for CORS (e.g. https://app.example.com,
# capacitor://localhost). Empty = allow all (development only).
ALLOWED_ORIGINS=
