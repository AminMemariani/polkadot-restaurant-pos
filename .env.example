# Flutter app build-time configuration. Copy to `.env` and fill in.
# Never commit the real `.env`.
#
# Pass to flutter run with:
#   flutter run --dart-define-from-file=.env

APP_ENV=dev
API_BASE_URL=https://api.restaurant-pos.dev
PAYMENTS_BACKEND_URL=http://localhost:8080

# Stripe — get the publishable key from https://dashboard.stripe.com/test/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_MERCHANT_IDENTIFIER=merchant.com.example.restaurantpos

# Supabase — Project Settings → API in the dashboard.
# `SUPABASE_ANON_KEY` is the publishable / anon key (safe to ship).
SUPABASE_URL=https://nynoqpbadxpnkhrpskgf.supabase.co
SUPABASE_ANON_KEY=sb_publishable_...
